# ──────────────────────────────────────────────────────────────────────────────
# CelebConnect Backend — Environment Variables
# Copy this file to .env and fill in your values for local development.
# On Railway, set these in the Railway dashboard (Variables tab) — no .env file needed.
# ──────────────────────────────────────────────────────────────────────────────

# ── WhatsApp Business Cloud API (required for sending messages) ───────────────
# Get these from https://developers.facebook.com → your WhatsApp app → API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxx...

# ── Scheduler ────────────────────────────────────────────────────────────────
# What time to send messages each day (24-hour format, server local time)
SEND_HOUR=9
SEND_MINUTE=0

# ── Server ───────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — only needed for local dev
PORT=3001

# ── Database (automatically set by Railway when you add a PostgreSQL plugin) ──
# For local dev: leave this blank to use the local JSON file store instead.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
